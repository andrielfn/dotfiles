{
  "wrap_guides": [120],
  "ui_font_size": 17,
  "theme": "Rosé Pine Dawn",
  "buffer_font_size": 18,
  // "base_keymap": "SublimeText",
  "tab_size": 2,
  "buffer_font_features": {
    "calt": false
  },
  "buffer_font_ligatures": true,
  "buffer_font_family": "JetBrains Mono Light",
  "buffer_line_height": {
    "custom": 1.8
  },
  "elixir": {
    "lsp": "next_ls"
  },
  "languages": {
    "Elixir": {
      "show_whitespaces": "selection",
      "language_servers": ["next-ls"]
    }
  },
  "file_scan_exclusions": [
    "**/.elixir-tools",
    "**/.github",
    "**/.elixir-tools",
    "**/_build",
    "**/.git",
    "**/.svn",
    "**/.hg",
    "**/CVS",
    "**/.DS_Store",
    "**/Thumbs.db",
    "**/.classpath",
    "**/.settings"
  ],
  "lsp": {
    // how you configure Next LS, notice the kebab casing
    "next-ls": {
      "initialization_options": {
        "extensions": {
          // example configuring the extensions
          "credo": { "enable": false }
        },
        "experimental": {
          // example configuring the experimental options
          "completions": { "enable": true }
        }
      }
    }
  },
  "file_types": {
    "JSON": ["prettierrc"],
    "HTML": ["heex"]
  }
}
