[color]
  diff = auto
  grep = auto
  interactive = auto
  status = auto
  branch = auto
  status = auto
  ui = auto

[alias]
  st = status -sb
  s = status -sb
  ci = commit
  cai = !"aicommits"
  wip = !git add . && git commit -am 'WIP :construction:'
  stash-all = stash save --include-untracked
  b = branch
  d = diff
  wd = diff --color-words
  pf = push --force-with-lease
  ap = add --patch
  ds = diff --staged
  tags = tag -l
  com = checkout master
  branches = branch -a
  remotes = remote -v
  sp = stash pop
  rc = rebase --continue
  rim = rebase -i master
  prune = fetch --prune
  r = reset
  rh = reset HEAD
  undo = reset --soft HEAD^
  fup = log --since '1 day ago' --oneline --author andriel.nuernberg@plataformatec.com.br
  rank = shortlog -sn --no-merges
  cl = "!git log $1..${2:-master} --oneline --no-merges --pretty=format:'- %s (%h)'"
  l = log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit
  ls = log --pretty=format:'%C(yellow)%h %C(blue)%ad%C(red)%d %C(reset)%s%C(green) [%cn]' --decorate --date=short
  lf = log --pretty=format:'%C(yellow)%h %C(blue)%ad%C(red)%d %C(reset)%s%C(green) [%cn]' --decorate --date=short --numstat
  co = checkout
  fix = commit --amend
  fixx = !git add . && git commit --amend --no-edit
  pom = push origin master
  latest = for-each-ref --count=10 --sort=-committerdate --format='%(committerdate:short) %(refname:short)'
  lol = !"git add -A; git commit -am \"$(echo $(curl -s http://whatthecommit.com/index.txt)\"\")\""
  m = !"git co main 2> /dev/null || git co master"


[core]
  editor = subl -w
  excludesfile = ~/.gitignore
  pager = diff-so-fancy | less --tabs=1,5 -R
  whitespace = warn

[push]
  default = current
  followTags = true

[includeIf "gitdir:~/"]
  path = .gitconfig-personal
[includeIf "gitdir:~/Stord/"]
  path = .gitconfig-work

[merge]
  ff = false
  conflictstyle = diff3

[pull]
  rebase = true

[commit]
  template = ~/.gitmessage
  gpgsign = true

[status]
  showUntrackedFiles = all

