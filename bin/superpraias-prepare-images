#!/bin/sh

# mkdir -p output

quality=${1:-80};
max_dim=${2:-1080};
source_files=${3:-*.jpg};

echo "Converting all ${source_files} images (${quality} quality, ${max_dim}px max) to output/...";

mkdir -p output 2> /dev/null;

convert "${source_files}" -colorspace sRGB -resize ${max_dim}x${max_dim} -set filename:new '%p' -density 72 -format JPG -quality ${quality} 'output/%[filename:new].jpg';
# convert ./*.(jpg|JPG|jpeg) -resize 1080x -quality 90 -set filename:area "%p" output/%[filename:area].jpg
