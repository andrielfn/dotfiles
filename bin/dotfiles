#!/usr/bin/env bash

# =============================================================================
# DOTFILES MANAGEMENT COMMAND
# =============================================================================

set -euo pipefail

DOTFILES_DIR="$HOME/.dotfiles"

# Source utilities with absolute paths
SCRIPTS_DIR="$DOTFILES_DIR/scripts"
source "$SCRIPTS_DIR/utils.sh"

# Temporarily change to scripts directory for config.sh relative sourcing
pushd "$SCRIPTS_DIR" > /dev/null
source "./config.sh"
popd > /dev/null

# =============================================================================
# DEPENDENCY DEFINITIONS (single source of truth)
# =============================================================================

# Homebrew packages are defined in a single Brewfile (source of truth):
#   ./Brewfile (repo root)
BREWFILE="$DOTFILES_DIR/Brewfile"

# Emit each mapping destination (tilde-expanded), one per line. Single source
# of truth for the symlink loops in status/doctor/clean.
mapping_dests() {
    local src dest
    while IFS=: read -r src dest; do
        [[ "$src" =~ ^[[:space:]]*# ]] && continue
        [[ -z "$src" ]] && continue
        printf '%s\n' "${dest/#\~/$HOME}"
    done < "$DOTFILES_DIR/config/mapping.cfg"
}

# Oh My Zsh custom plugins: "name|repo_url"
OMZ_CUSTOM_PLUGINS=(
    "fzf-tab|https://github.com/Aloxaf/fzf-tab"
    "forgit|https://github.com/wfxr/forgit"
    "zsh-autopair|https://github.com/hlissner/zsh-autopair"
    "you-should-use|https://github.com/MichaelAquilina/zsh-you-should-use"
    "zsh-autosuggestions|https://github.com/zsh-users/zsh-autosuggestions"
    "zsh-syntax-highlighting|https://github.com/zsh-users/zsh-syntax-highlighting"
)

# =============================================================================
# COMMANDS
# =============================================================================

dotfiles_update() {
    print_step "Updating dotfiles"

    # Pull latest changes
    if git -C "$DOTFILES_DIR" pull origin main; then
        print_success "Dotfiles updated"

        # Relink configurations
        dotfiles_link
    else
        print_error "Failed to update dotfiles"
        return 1
    fi
}

dotfiles_link() {
    print_step "Linking configurations"
    
    # Run setup_configurations with dotfiles directory
    setup_configurations "$DOTFILES_DIR"
    
    print_success "Configurations linked"
}

dotfiles_status() {
    print_step "Dotfiles Status"

    # Git status
    printf "\n${BOLD}Git Status:${RESET}\n"
    git -C "$DOTFILES_DIR" status --short
    
    # Check for broken symlinks
    printf "\n${BOLD}Checking symlinks:${RESET}\n"
    local broken_links=0 dest
    while IFS= read -r dest; do
        if [[ -L "$dest" && ! -e "$dest" ]]; then
            print_error "Broken: $dest"
            broken_links=$((broken_links + 1))
        elif [[ ! -e "$dest" ]]; then
            print_warning "Missing: $dest"
        fi
    done < <(mapping_dests)

    if [[ $broken_links -eq 0 ]]; then
        print_success "All symlinks healthy"
    fi
    
    # Environment info
    printf "\n${BOLD}Environment:${RESET}\n"
    if [[ -d "$HOME/Work" ]] || [[ -d "$HOME/work" ]]; then
        echo "Type: work"
    else
        echo "Type: personal"
    fi
    echo "Shell: $SHELL"
    echo "Dotfiles: $DOTFILES_DIR"
}

dotfiles_setup() {
    print_step "Setting up dotfiles dependencies"

    # 1. Homebrew
    if ! command -v brew &>/dev/null; then
        print_info "Installing Homebrew..."
        /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
        if [[ -f "/opt/homebrew/bin/brew" ]]; then
            eval "$(/opt/homebrew/bin/brew shellenv)"
        elif [[ -f "/usr/local/bin/brew" ]]; then
            eval "$(/usr/local/bin/brew shellenv)"
        fi
        print_success "Homebrew installed"
    else
        print_success "Homebrew already installed"
    fi

    # 2. Brew packages (from ./Brewfile — single source of truth)
    print_step "Installing brew packages"
    brew bundle --file="$BREWFILE" || print_warning "Some packages failed to install"

    # 3. Link configurations (mise reads ~/.config/mise/config.toml — link first)
    dotfiles_link

    # 4. Mise tools (runtimes + dev CLIs from config/mise/config.toml)
    if command -v mise &>/dev/null; then
        print_step "Installing mise tools"
        mise install || print_warning "Some mise tools failed to install"
    fi

    # 5. Oh My Zsh
    print_step "Checking Oh My Zsh"
    if [[ ! -d "$HOME/.oh-my-zsh" ]]; then
        print_info "Installing Oh My Zsh..."
        RUNZSH=no KEEP_ZSHRC=yes sh -c "$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)"
        print_success "Oh My Zsh installed"
    else
        print_success "Oh My Zsh already installed"
    fi

    # 6. Custom plugins
    print_step "Checking Oh My Zsh plugins"
    local plugins_dir="$HOME/.oh-my-zsh/custom/plugins"
    mkdir -p "$plugins_dir"

    for entry in "${OMZ_CUSTOM_PLUGINS[@]}"; do
        local name="${entry%%|*}"
        local repo="${entry##*|}"

        if [[ -d "$plugins_dir/$name" ]]; then
            print_success "$name"
        else
            print_info "Cloning $name..."
            if git clone --depth=1 "$repo" "$plugins_dir/$name" 2>/dev/null; then
                print_success "$name installed"
            else
                print_error "Failed to clone $name"
            fi
        fi
    done

    # 7. Set default shell to zsh if needed
    if [[ "$SHELL" != *"zsh"* ]]; then
        print_info "Setting default shell to zsh..."
        local zsh_path
        zsh_path=$(which zsh)
        if grep -qx "$zsh_path" /etc/shells; then
            chsh -s "$zsh_path"
            print_success "Default shell set to zsh"
        else
            print_warning "zsh not in /etc/shells — add it with: sudo sh -c 'echo $zsh_path >> /etc/shells'"
        fi
    fi

    echo ""
    print_success "Setup complete! Run 'exec \$SHELL -l' to reload."
}

dotfiles_ssh() {
    bash "$DOTFILES_DIR/installers/ssh.sh"
}

dotfiles_secrets() {
    bash "$DOTFILES_DIR/installers/secrets.sh"
}

dotfiles_signing() {
    bash "$DOTFILES_DIR/installers/git-signing.sh"
}

dotfiles_doctor() {
    print_step "Running diagnostics"

    local issues=0

    # Check shell
    if [[ "$SHELL" != *"zsh"* ]]; then
        print_warning "Default shell is not zsh"
        issues=$((issues + 1))
    else
        print_success "Shell: zsh"
    fi

    # Check dotfiles symlink
    if [[ -L "$HOME/.zshrc" ]] && [[ -e "$HOME/.zshrc" ]]; then
        print_success "zshrc linked"
    else
        print_warning "zshrc not properly linked"
        issues=$((issues + 1))
    fi

    # Check Oh My Zsh
    if [[ -d "$HOME/.oh-my-zsh" ]]; then
        print_success "Oh My Zsh"
    else
        print_warning "Oh My Zsh not installed"
        issues=$((issues + 1))
    fi

    # Check brew packages (against ./Brewfile)
    printf "\n${BOLD}Brew packages:${RESET}\n"
    if brew bundle check --file="$BREWFILE" >/dev/null 2>&1; then
        print_success "Brewfile satisfied"
    else
        print_warning "Brewfile has missing entries (run 'dotfiles setup'):"
        { brew bundle check --file="$BREWFILE" --verbose 2>/dev/null \
            | grep -iE 'needs to be installed' | sed 's/^/    /'; } || true
        issues=$((issues + 1))
    fi

    # Drift: top-level packages installed but NOT in the Brewfile
    printf "\n${BOLD}Untracked packages (installed, not in Brewfile):${RESET}\n"
    local extra_formulae extra_casks
    extra_formulae=$(comm -23 \
        <(brew leaves -r 2>/dev/null | sort -u) \
        <(brew bundle list --formula --file="$BREWFILE" 2>/dev/null | sort -u) || true)
    extra_casks=$(comm -23 \
        <(brew list --cask 2>/dev/null | sort -u) \
        <(brew bundle list --cask --file="$BREWFILE" 2>/dev/null | sort -u) || true)
    if [[ -z "$extra_formulae" && -z "$extra_casks" ]]; then
        print_success "None — machine matches Brewfile"
    else
        [[ -n "$extra_formulae" ]] && { printf "  formulae:\n"; printf '%s\n' "$extra_formulae" | sed 's/^/    /'; }
        [[ -n "$extra_casks" ]] && { printf "  casks:\n"; printf '%s\n' "$extra_casks" | sed 's/^/    /'; }
        print_info "Adopt: add to Brewfile  |  Remove: brew bundle cleanup --force --file=$BREWFILE"
    fi

    # Check mise tools
    printf "\n${BOLD}Mise tools:${RESET}\n"
    if command -v mise &>/dev/null; then
        if mise ls --missing 2>/dev/null | grep -q .; then
            print_warning "Missing mise tools — run 'mise install'"
            issues=$((issues + 1))
        else
            print_success "All mise tools installed"
        fi
    else
        print_warning "mise not installed"
        issues=$((issues + 1))
    fi

    # Check Oh My Zsh plugins
    printf "\n${BOLD}Oh My Zsh plugins:${RESET}\n"
    for entry in "${OMZ_CUSTOM_PLUGINS[@]}"; do
        local name="${entry%%|*}"
        if [[ -d "$HOME/.oh-my-zsh/custom/plugins/$name" ]]; then
            print_success "$name"
        else
            print_warning "Missing: $name"
            issues=$((issues + 1))
        fi
    done

    # Check symlinks from the mapping file
    printf "\n${BOLD}Symlinks:${RESET}\n"
    local link_issues=0 dest
    while IFS= read -r dest; do
        if [[ -L "$dest" && ! -e "$dest" ]]; then
            print_error "Broken: $dest"; link_issues=$((link_issues + 1))
        elif [[ ! -e "$dest" ]]; then
            print_warning "Missing: $dest"; link_issues=$((link_issues + 1))
        fi
    done < <(mapping_dests)
    if [[ $link_issues -eq 0 ]]; then
        print_success "All mapped symlinks healthy"
    else
        issues=$((issues + link_issues))
    fi

    # Check git signing configuration
    printf "\n${BOLD}Git signing:${RESET}\n"
    [[ "$(git config --get gpg.format || true)" == "ssh" ]] \
        && print_success "gpg.format = ssh" \
        || { print_warning "gpg.format is not ssh"; issues=$((issues + 1)); }
    local signingkey; signingkey="$(git config --get user.signingkey || true)"
    [[ -n "$signingkey" ]] \
        && print_success "signingkey = $signingkey" \
        || { print_warning "user.signingkey not set"; issues=$((issues + 1)); }
    [[ "$(git config --get commit.gpgsign || true)" == "true" ]] \
        && print_success "commit.gpgsign = true" \
        || { print_warning "commit.gpgsign not enabled"; issues=$((issues + 1)); }
    local signers; signers="$(git config --get gpg.ssh.allowedSignersFile || true)"; signers="${signers/#\~/$HOME}"
    [[ -n "$signers" && -f "$signers" ]] \
        && print_success "allowed_signers present" \
        || { print_warning "allowed_signers missing"; issues=$((issues + 1)); }

    # Check SSH key (auth + signing)
    printf "\n${BOLD}SSH key:${RESET}\n"
    if [[ -f "$HOME/.ssh/id_ed25519" && -f "$HOME/.ssh/id_ed25519.pub" ]]; then
        print_success "id_ed25519 present"
        local pub; pub="$(awk '{print $2}' "$HOME/.ssh/id_ed25519.pub" 2>/dev/null || true)"
        if [[ -n "$pub" ]] && ssh-add -L 2>/dev/null | grep -qF "$pub"; then
            print_success "loaded in ssh-agent"
        else
            print_warning "not loaded in agent — run: ssh-add --apple-use-keychain ~/.ssh/id_ed25519"
            issues=$((issues + 1))
        fi
    else
        print_warning "id_ed25519 missing — run 'dotfiles ssh'"
        issues=$((issues + 1))
    fi

    # Check secrets
    printf "\n${BOLD}Secrets:${RESET}\n"
    if [[ -f "$DOTFILES_DIR/shell/secrets" ]]; then
        if grep -q 'op://' "$DOTFILES_DIR/shell/secrets" 2>/dev/null; then
            print_warning "shell/secrets has unresolved op:// refs — run 'dotfiles secrets'"
            issues=$((issues + 1))
        else
            local nvars; nvars="$(grep -cE '^export ' "$DOTFILES_DIR/shell/secrets" 2>/dev/null || true)"
            print_success "shell/secrets present (${nvars:-0} vars)"
        fi
    else
        print_warning "shell/secrets missing — run 'dotfiles secrets'"
        issues=$((issues + 1))
    fi
    if grep -q 'CHANGEME' "$DOTFILES_DIR/shell/secrets.tpl" 2>/dev/null; then
        print_warning "shell/secrets.tpl still has CHANGEME placeholders"
        issues=$((issues + 1))
    fi
    local age_key="${SOPS_AGE_KEY_FILE:-$HOME/.config/sops/age/keys.txt}"
    if [[ -f "$age_key" ]]; then
        print_success "SOPS age key present"
    else
        print_warning "SOPS age key missing ($age_key) — run 'dotfiles secrets'"
        issues=$((issues + 1))
    fi

    # Check 1Password CLI (setup-time dependency)
    printf "\n${BOLD}1Password CLI:${RESET}\n"
    if command -v op >/dev/null 2>&1; then
        print_success "op installed ($(op --version 2>/dev/null || true))"
    else
        print_warning "op not installed — needed for 'dotfiles ssh' / 'dotfiles secrets'"
    fi

    echo ""
    if [[ $issues -eq 0 ]]; then
        print_success "No issues found"
    else
        print_warning "Found $issues issue(s) — see suggestions above"
    fi
}

dotfiles_edit() {
    print_step "Opening dotfiles in ${EDITOR:-vim}"
    
    # Use EDITOR if set, otherwise default to vim
    "${EDITOR:-vim}" "$DOTFILES_DIR"
}

dotfiles_reload() {
    print_step "Reloading shell configuration"
    
    if [[ -f "$HOME/.zshrc" ]]; then
        print_success "Restarting shell to reload configuration"
        exec "$SHELL" -l
    else
        print_error "No .zshrc found"
        return 1
    fi
}

dotfiles_clean() {
    print_step "Cleaning broken symlinks"
    
    local cleaned=0 dest
    while IFS= read -r dest; do
        if [[ -L "$dest" && ! -e "$dest" ]]; then
            rm "$dest"
            print_success "Removed broken symlink: $dest"
            cleaned=$((cleaned + 1))
        fi
    done < <(mapping_dests)
    
    if [[ $cleaned -eq 0 ]]; then
        print_success "No broken symlinks found"
    else
        print_success "Cleaned $cleaned broken symlink(s)"
    fi
}

dotfiles_sync() {
    print_step "Syncing dotfiles to remote"

    # Check if there are changes to commit (modified, added, or untracked files)
    if ! git -C "$DOTFILES_DIR" diff --quiet || ! git -C "$DOTFILES_DIR" diff --cached --quiet || [[ -n $(git -C "$DOTFILES_DIR" ls-files --others --exclude-standard) ]]; then
        print_question "Commit message (or press Enter for default): "
        read -r commit_msg

        if [[ -z "$commit_msg" ]]; then
            commit_msg="Update dotfiles configuration"
        fi

        git -C "$DOTFILES_DIR" add .
        git -C "$DOTFILES_DIR" commit -m "$commit_msg"
        print_success "Changes committed"
    else
        print_success "No changes to commit"
    fi

    # Push to remote
    if git -C "$DOTFILES_DIR" push; then
        print_success "Changes pushed to remote"
    else
        print_error "Failed to push changes"
        return 1
    fi
}

dotfiles_help() {
    printf "${BOLD}dotfiles - Dotfiles management${RESET}\n"
    echo ""
    printf "${BOLD}USAGE:${RESET}\n"
    echo "    dotfiles <command>"
    echo ""
    printf "${BOLD}COMMANDS:${RESET}\n"
    echo "    setup     Install all dependencies (brew, mise, oh-my-zsh, plugins)"
    echo "    ssh       Materialize SSH key from 1Password into ~/.ssh + keychain"
    echo "    secrets   Inject secrets from 1Password into shell/secrets (op inject)"
    echo "    signing   Register SSH key on GitHub (auth + signing) via gh"
    echo "    edit      Open dotfiles in \$EDITOR"
    echo "    update    Pull latest changes and relink configurations"
    echo "    link      Link all configurations from mapping file"
    echo "    status    Show current dotfiles status"
    echo "    doctor    Check for missing dependencies and issues"
    echo "    reload    Reload shell configuration"
    echo "    clean     Remove broken symlinks"
    echo "    sync      Commit and push changes"
    echo "    help      Show this help message"
}

# =============================================================================
# MAIN
# =============================================================================

case "${1:-help}" in
    setup)
        dotfiles_setup
        ;;
    ssh)
        dotfiles_ssh
        ;;
    secrets)
        dotfiles_secrets
        ;;
    signing)
        dotfiles_signing
        ;;
    edit)
        dotfiles_edit
        ;;
    update)
        dotfiles_update
        ;;
    link)
        dotfiles_link
        ;;
    status)
        dotfiles_status
        ;;
    doctor)
        dotfiles_doctor
        ;;
    reload)
        dotfiles_reload
        ;;
    clean)
        dotfiles_clean
        ;;
    sync)
        dotfiles_sync
        ;;
    help|--help|-h)
        dotfiles_help
        ;;
    *)
        print_error "Unknown command: $1"
        dotfiles_help
        exit 1
        ;;
esac