{
  "terminal": {
    "font_weight": 300.0
  },
  "context_servers": {
    "mcp-server-context7": {
      "enabled": false,
      "remote": false,
      "settings": {}
    }
  },
  "cli_default_open_behavior": "new_window",
  "collaboration_panel": {
    "dock": "right"
  },
  "diff_view_style": "unified",
  "git_panel": {
    "tree_view": false,
    "file_icons": false,
    "dock": "right"
  },
  "outline_panel": {
    "dock": "right"
  },
  "sticky_scroll": {
    "enabled": false
  },
  "preferred_line_length": 2000,
  "soft_wrap": "editor_width",
  "colorize_brackets": false,
  "title_bar": {
    "show_menus": false
  },
  "prettier": {
    "allowed": false
  },
  "toolbar": {
    "code_actions": false
  },
  "use_smartcase_search": true,
  // "centered_layout": {
  //   "left_padding": 2.1999998092651367
  // },
  "on_last_window_closed": "platform_default",
  "close_on_file_delete": true,
  "when_closing_with_no_tabs": "close_window",
  "edit_predictions": {
    "allow_data_collection": "yes",
    "provider": "zed",
    "mode": "eager",
    "copilot": {
      "enable_next_edit_suggestions": true,
      "proxy": null,
      "proxy_no_verify": null,
      "enterprise_uri": null,
    },
  },
  "agent_servers": {
    "claude-acp": {
      "type": "registry",
      "default_mode": "acceptEdits"
    },
    "github-copilot": {
      "type": "registry"
    },
  },
  "tabs": {
    "close_position": "right",
    "git_status": true,
    "file_icons": true
  },
  "show_edit_predictions": true,
  "git": {
    "inline_blame": {
      "enabled": false
    },
    "blame": {
      "show_avatar": true
    }
  },
  "icon_theme": {
    "mode": "dark",
    "light": "Bearded Icons",
    "dark": "Catppuccin Latte"
  },
  "ssh_connections": [
    {
      "host": "192.168.0.10",
      "username": "andrielfn",
      "projects": [
        {
          "paths": [
            "/etc"
          ]
        },
        {
          "paths": [
            "/opt"
          ]
        }
      ]
    },
    {
      "host": "192.168.0.10",
      "username": "andrielfn",
      "projects": [],
    },
  ],
  "scroll_beyond_last_line": "off",
  "telemetry": {
    "metrics": false,
  },
  "agent": {
    "sidebar_side": "right",
    "dock": "right",
    "default_model": {
      "effort": "high",
      "provider": "anthropic",
      "model": "claude-opus-4-8",
      "enable_thinking": true
    },
    "favorite_models": [],
    "model_parameters": []
  },
  "wrap_guides": [
    120
  ],
  "ui_font_size": 17,
  "theme": {
    "mode": "light",
    "light": "Snowday",
    "dark": "One Dark"
  },
  "buffer_font_size": 17,
  "tab_size": 2,
  "buffer_font_features": {
    "calt": false,
  },
  "buffer_font_family": "Cascadia Code NF",
  "buffer_font_weight": 200,
  "buffer_line_height": {
    "custom": 1.8,
  },
  "languages": {
    "Elixir": {
      "language_servers": [
        "dexter",
        "!expert",
        "!elixir-ls",
        "!next-ls",
        "!lexical",
        "tailwindcss-language-server",
        "emmet-language-server",
        "vscode-html-language-server"
      ]
    },
    "EEx": {
      "language_servers": [
        "dexter",
        "!elixir-ls",
        "!expert"
      ]
    },
    "HEEx": {
      "language_servers": [
        "dexter",
        "!expert",
        "!elixir-ls",
        "!next-ls",
        "!lexical",
        "tailwindcss-language-server",
        "emmet-language-server",
        "vscode-html-language-server"
      ]
    }
  },
  "lsp": {
    // "expert": {
    //   "binary": {
    //     "arguments": [
    //       "--stdio"
    //     ]
    //   }
    // },
    "dexter": {
      "binary": {
        "path": "/Users/andriel/.local/share/mise/shims/dexter",
        "arguments": [
          "lsp"
        ]
      }
    }
  },
  "file_scan_exclusions": [
    "**/.elixir-tools",
    "**/.elixir-tools",
    "**/_build",
    "**/deps",
    "**/.git",
    "**/.svn",
    "**/.hg",
    "**/CVS",
    "**/.DS_Store",
    "**/Thumbs.db",
    "**/.classpath",
    "**/.settings",
    "**/node_modules",
    // "**/rel",
    "**/.docker",
    "**/.nix*",
    "**/.postgres",
    "**/.lefthook",
    "**/.vscode",
    "**/.direnv",
    "**/.dexter*",
    "**/.playwright-mcp",
    "**/*.ipynb"
  ],
  "file_types": {
    "JSON": [
      "prettierrc"
    ],
    "Shell Script": [
      "envrc"
    ]
  },
  "project_panel": {
    "dock": "left",
    "hide_root": false,
    "git_status": true,
    "folder_icons": true,
    "entry_spacing": "comfortable",
    "auto_fold_dirs": false
  }
}
